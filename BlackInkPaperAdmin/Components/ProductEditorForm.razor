@inject AdminSession Session
@inject ProductReferenceApiClient ReferenceApi

<EditForm Model="Model" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (!string.IsNullOrWhiteSpace(ErrorMessage)&& ErrorMessage != "errorMessage")
    {
        <p class="error-text">@ErrorMessage</p>
    }

    @if (!string.IsNullOrWhiteSpace(_referenceError))
    {
        <p class="error-text">@_referenceError</p>
    }

    <TabSet @ref="_tabs">
        <TabPage Title="General Info">
            <div class="editor-layout">
                <div class="editor-column">
                    <section class="panel">
                        <h2>Product Basics</h2>
                        <div class="form-group">
                            <label>Product Name</label>
                            <InputText @bind-Value="Model.Name" class="input" placeholder="e.g. Vintage Canvas Print" />
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Product ID</label>
                                <InputText @bind-Value="Model.ProductId" class="input" />
                            </div>
                            <div class="form-group">
                                <label>Slug</label>
                                <InputText @bind-Value="Model.Slug" class="input" />
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Name Code</label>
                                <InputText @bind-Value="Model.NameCode" class="input" />
                            </div>
                            <div class="form-group">
                                <label>Print Name</label>
                                <InputText @bind-Value="Model.PrintName" class="input" />
                            </div>
                        </div>
                    </section>

                    <section class="panel">
                        <h2>Status & Visibility</h2>
                        <div class="form-group">
                            <label class="check"><InputCheckbox @bind-Value="Model.IsAvailable" /> Product is Available</label>
                            <label class="check"><InputCheckbox @bind-Value="Model.IsFeatured" /> Feature on Homepage</label>
                            <label class="check"><InputCheckbox @bind-Value="Model.IsUsingStandardVariants" /> Use Standard Variants</label>
                        </div>
                    </section>
                </div>

                <div class="editor-column">
                    <section class="panel">
                        <h2>Catalog & Discovery</h2>

                        <div class="lookup-block">
                            <div class="lookup-header">
                                <h3>Artist</h3>
                                <p class="muted">Primary creator of this work.</p>
                            </div>

                            <InputSelect @bind-Value="Model.ArtistId" class="input" disabled="@(!IsCreateMode || _loadingReferences)">
                                <option value="0">Select artist</option>
                                @foreach (var artist in _artists)
                                {
                                    <option value="@artist.Id">@artist.DisplayName@(artist.IsVerified ? " • verified" : "")</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="lookup-block">
                            <div class="lookup-header">
                                <h3>Category</h3>
                                <p class="muted">Main collection for this product.</p>
                            </div>

                            <div class="mode-switch">
                                <button type="button" class="@ModeButtonClass(_categoryMode, LookupMode.Select)" @onclick='() => _categoryMode = LookupMode.Select'>Select</button>
                                <button type="button" class="@ModeButtonClass(_categoryMode, LookupMode.Create)" @onclick='() => _categoryMode = LookupMode.Create'>New</button>
                            </div>

                            @if (_categoryMode == LookupMode.Select)
                            {
                                <select class="input" value="@Model.CategoryId" @onchange="OnCategoryChanged">
                                    <option value="0">Select category</option>
                                    @foreach (var category in _categories)
                                    {
                                        <option value="@category.Id">@category.PrintName</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <div class="lookup-create-grid">
                                    <InputText @bind-Value="_newCategory.NameCode" class="input" placeholder="Code" />
                                    <InputText @bind-Value="_newCategory.Name" class="input" placeholder="Name" />
                                    <InputText @bind-Value="_newCategory.PrintName" class="input" placeholder="Display Name" />
                                    <InputText @bind-Value="_newCategory.Slug" class="input" placeholder="Slug" />
                                </div>
                                <button type="button" class="button secondary slim" @onclick="CreateCategoryAsync" disabled="@_creatingCategory">
                                    @(_creatingCategory ? "Creating..." : "Add Category")
                                </button>
                            }
                        </div>

                        <div class="lookup-block">
                            <div class="lookup-header">
                                <h3>Tags</h3>
                                <p class="muted">Keywords for search and filtering.</p>
                            </div>

                            <div class="tag-selection">
                                @foreach (var tag in _tags)
                                {
                                    <label class="tag-item" style='@GetTagStyle(tag)'>
                                        <input type="checkbox" checked="@Model.TagIds.Contains(tag.Id)" @onchange='(e) => OnTagToggled(tag.Id, e)' />
                                        @tag.Name
                                    </label>
                                }
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </TabPage>

        <TabPage Title="Content & Specs">
            <div class="editor-layout">
                <div class="editor-column">
                    <section class="panel">
                        <h2>Description</h2>
                        <div class="form-group">
                            <label>Short Description</label>
                            <InputTextArea @bind-Value="Model.ShortDescription" class="input" rows="2" />
                        </div>

                        <div class="form-group">
                            <label>Full Description</label>
                            <InputTextArea @bind-Value="Model.Description" class="input" rows="10" />
                        </div>
                    </section>
                </div>

                <div class="editor-column">
                    <section class="panel">
                        <h2>Art Specifications</h2>
                        <p class="muted" style="margin-bottom: 20px;">Detailed technical specs for the linked artwork.</p>

                        <div class="form-group">
                            <label>Material</label>
                            <InputText @bind-Value="Model.Material" class="input" />
                        </div>
                        
                        <div class="form-group">
                            <label>Weight (Grams)</label>
                            <InputNumber @bind-Value="Model.WeightGrams" class="input" />
                        </div>

                        <div class="form-group">
                            <label>File Format</label>
                            <InputText @bind-Value="Model.FileFormat" class="input" />
                        </div>
                        
                        <div class="form-group">
                            <label>Pixel Dimensions</label>
                            <InputText @bind-Value="Model.PixelDimensions" class="input" />
                        </div>
                    </section>
                </div>
            </div>
        </TabPage>

        <TabPage Title="Pricing & Stock">
            <div class="editor-layout" style="grid-template-columns: 1fr 1fr;">
                <section class="panel">
                    <h2>Pricing Details</h2>
                    <div class="form-group">
                        <label>Base Price (Original)</label>
                        <InputNumber @bind-Value="Model.BasePrice" class="input" />
                    </div>
                    
                    <div class="form-group">
                        <label>Final Price (Sale)</label>
                        <InputNumber @bind-Value="Model.FinalPrice" class="input" />
                    </div>

                    <div class="form-group">
                        <label>Currency Code</label>
                        <InputText @bind-Value="Model.CurrencyCode" class="input" />
                    </div>
                </section>

                <section class="panel">
                    <h2>Inventory Control</h2>
                    <div class="form-group">
                        <label>Stock Quantity</label>
                        <InputNumber @bind-Value="Model.StockQuantity" class="input" placeholder="Leave empty for unlimited digital" />
                        <p class="muted" style="font-size: 0.8rem; margin-top: 8px;">For digital products, stock is typically handled by fulfillment settings.</p>
                    </div>
                </section>
            </div>
        </TabPage>

        <TabPage Title="Media Gallery">
            <div class="editor-column">
                <section class="panel">
                    <h2>Direct Media Links</h2>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Cover Image URL</label>
                            <InputText @bind-Value="Model.CoverImageUrl" class="input" />
                        </div>

                        <div class="form-group">
                            <label>Header Image URL</label>
                            <InputText @bind-Value="Model.HeaderImageUrl" class="input" />
                        </div>
                    </div>
                </section>

                <section class="panel" style="margin-top: 24px;">
                    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h2 style="margin: 0; border: 0;">Product Gallery (Cloudinary Integration)</h2>
                        <button type="button" class="button secondary slim" @onclick="AddImage">Add Gallery Item</button>
                    </div>

                    <div class="image-grid-editor">
                        @foreach (var img in Model.Images)
                        {
                            <div class="image-card">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                                    <label class="check" style="margin: 0;"><input type="checkbox" checked="@img.IsPrimary" @onchange="@(e => SetPrimaryImage(img))" /> Primary</label>
                                    <button type="button" class="button secondary slim" @onclick="@(() => RemoveImage(img))">Remove</button>
                                </div>
                                
                                @if (!string.IsNullOrWhiteSpace(img.BaseUrl))
                                {
                                    <img src="@img.BaseUrl" class="image-preview" alt="preview" />
                                }
                                else
                                {
                                    <div class="image-preview" style="display: flex; align-items: center; justify-content: center; color: var(--muted);">No Preview</div>
                                }

                                <div class="form-group">
                                    <label>Alt Text</label>
                                    <InputText @bind-Value="img.AltText" class="input slim" placeholder="Image description" />
                                </div>
                                <div class="form-group">
                                    <label>Cloudinary Public ID</label>
                                    <InputText @bind-Value="img.PublicId" class="input slim" />
                                </div>
                                <div class="form-group">
                                    <label>Direct URL</label>
                                    <InputText @bind-Value="img.BaseUrl" class="input slim" />
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label>W</label>
                                        <InputNumber @bind-Value="img.Width" class="input slim" />
                                    </div>
                                    <div class="form-group">
                                        <label>H</label>
                                        <InputNumber @bind-Value="img.Height" class="input slim" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    @if (!Model.Images.Any())
                    {
                        <p class="muted" style="text-align: center; padding: 40px;">No gallery images. Gallery is recommended for modern listings.</p>
                    }
                </section>
            </div>
        </TabPage>

        @if (!Model.IsUsingStandardVariants)
        {
            <TabPage Title="Custom Variants">
                <section class="panel">
                    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h2 style="margin: 0; border: 0;">Custom Fulfillment Variants</h2>
                        <button type="button" class="button secondary slim" @onclick="AddVariant">Add Variant Group</button>
                    </div>

                    @foreach (var variant in Model.Variants)
                    {
                        <div class="variant-box">
                            <div class="variant-header">
                                <div style="flex: 1; margin-right: 16px;">
                                    <InputText @bind-Value="variant.Label" class="input" placeholder="Group Name (e.g. Size)" style="margin-bottom: 0;" />
                                </div>
                                <button type="button" class="button secondary slim" @onclick="@(() => AddOption(variant))">Add Option</button>
                                <button type="button" class="button secondary slim" style="margin-left: 8px;" @onclick="@(() => RemoveVariant(variant))">Delete Group</button>
                            </div>

                            <div class="variant-options">
                                @foreach (var opt in variant.Options)
                                {
                                    <div class="option-row">
                                        <div class="form-group" style="margin: 0;">
                                            <label>Value</label>
                                            <InputText @bind-Value="opt.Value" class="input slim" style="margin: 0;" />
                                        </div>
                                        <div class="form-group" style="margin: 0;">
                                            <label>Abs. Price</label>
                                            <InputNumber @bind-Value="opt.AbsolutePrice" class="input slim" style="margin: 0;" />
                                        </div>
                                        <div class="form-group" style="margin: 0;">
                                            <label>SKU</label>
                                            <InputText @bind-Value="opt.Sku" class="input slim" style="margin: 0;" />
                                        </div>
                                        <div class="form-group" style="margin: 0;">
                                            <label>Type</label>
                                            <select class="input slim" @bind="opt.FulfillmentType" style="margin: 0;">
                                                <option value="0">Digital</option>
                                                <option value="1">Physical</option>
                                            </select>
                                        </div>
                                        <button type="button" class="button secondary slim" @onclick="@(() => RemoveOption(variant, opt))">×</button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </section>
            </TabPage>
        }
    </TabSet>

    <div class="form-actions">
        <div style="margin-right: auto; display: flex; gap: 8px;">
            <button type="button" class="button secondary" disabled="@(_tabs?.IsFirst ?? true)" @onclick="() => _tabs?.Previous()">Previous Step</button>
            <button type="button" class="button secondary" disabled="@(_tabs?.IsLast ?? true)" @onclick="() => _tabs?.Next()">Next Step</button>
        </div>
        <button class="button">@SubmitLabel</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired] public required ProductEditorModel Model { get; set; }
    [Parameter, EditorRequired] public required string SubmitLabel { get; set; }
    [Parameter, EditorRequired] public required EventCallback OnValidSubmit { get; set; }
    [Parameter] public string? ErrorMessage { get; set; } = null!;
    [Parameter] public bool IsCreateMode { get; set; }

    private TabSet? _tabs;

    private string? _referenceError;
    private bool _loadingReferences;
    private bool _creatingCategory;
    private bool _creatingSubCategory;
    private List<ArtistLookupDto> _artists = [];
    private List<ProductCategoryLookupDto> _categories = [];
    private List<ProductSubCategoryLookupDto> _subCategories = [];
    private List<ProductTagDto> _tags = [];
    private LookupMode _categoryMode = LookupMode.Select;
    private LookupMode _subCategoryMode = LookupMode.Select;
    private CategoryDraft _newCategory = new();
    private SubCategoryDraft _newSubCategory = new();
    private ArtistLookupDto? SelectedArtist => _artists.FirstOrDefault(x => x.Id == Model.ArtistId);
    private ProductCategoryLookupDto? SelectedCategory => _categories.FirstOrDefault(x => x.Id == Model.CategoryId);
    private ProductSubCategoryLookupDto? SelectedSubCategory => _subCategories.FirstOrDefault(x => x.Id == Model.SubCategoryId);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        await LoadReferenceDataAsync();
    }

    private void AddImage()
    {
        Model.Images.Add(new ProductImageModel 
        { 
            DisplayOrder = Model.Images.Count + 1,
            IsPrimary = !Model.Images.Any()
        });
    }

    private void RemoveImage(ProductImageModel img)
    {
        Model.Images.Remove(img);
        if (img.IsPrimary && Model.Images.Any())
        {
            Model.Images.First().IsPrimary = true;
        }
    }

    private void SetPrimaryImage(ProductImageModel img)
    {
        foreach (var i in Model.Images) i.IsPrimary = false;
        img.IsPrimary = true;
    }

    private void AddVariant()
    {
        Model.Variants.Add(new ProductVariantModel { Label = "Option Group" });
    }

    private void RemoveVariant(ProductVariantModel variant)
    {
        Model.Variants.Remove(variant);
    }

    private void AddOption(ProductVariantModel variant)
    {
        variant.Options.Add(new ProductVariantOptionModel { Value = "New Option", FulfillmentType = 1 });
    }

    private void RemoveOption(ProductVariantModel variant, ProductVariantOptionModel option)
    {
        variant.Options.Remove(option);
    }

    private async Task LoadReferenceDataAsync()
    {
        _loadingReferences = true;
        _referenceError = null;

        var artistTask = ReferenceApi.GetArtistsAsync(Session);
        var categoryTask = ReferenceApi.GetCategoriesAsync(Session);
        var tagTask = ReferenceApi.GetTagsAsync(Session);

        try
        {
            await Task.WhenAll(artistTask, categoryTask, tagTask);

            var artistResponse = await artistTask;
            if (!artistResponse.Success || artistResponse.Data is null)
            {
                _referenceError = artistResponse.Message;
                _loadingReferences = false;
                return;
            }

            var categoryResponse = await categoryTask;
            if (!categoryResponse.Success || categoryResponse.Data is null)
            {
                _referenceError = categoryResponse.Message;
                _loadingReferences = false;
                return;
            }

            var tagResponse = await tagTask;
            if (!tagResponse.Success || tagResponse.Data is null)
            {
                _referenceError = tagResponse.Message;
                _loadingReferences = false;
                return;
            }

            _artists = artistResponse.Data.ToList();
            _categories = categoryResponse.Data.ToList();
            _tags = tagResponse.Data.ToList();
            await LoadSubCategoriesAsync(Model.CategoryId);
            _loadingReferences = false;
        }
        catch (Exception ex)
        {
            throw new Exception(ex.Message, ex);
        }

    }
    private async Task OnCategoryChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var categoryId))
        {
            categoryId = 0;
        }

        Model.CategoryId = categoryId;
        Model.SubCategoryId = 0;
        await LoadSubCategoriesAsync(categoryId);
    }
    private async Task LoadSubCategoriesAsync(int? categoryId)
    {
        _subCategories = [];
        if (categoryId is null or <= 0)
        {
            return;
        }

        var subCategoryResponse = await ReferenceApi.GetSubCategoriesAsync(Session, categoryId);
        if (!subCategoryResponse.Success || subCategoryResponse.Data is null)
        {
            _referenceError = subCategoryResponse.Message;
            return;
        }

        _subCategories = subCategoryResponse.Data.ToList();

        if (Model.SubCategoryId > 0 && _subCategories.All(x => x.Id != Model.SubCategoryId))
        {
            Model.SubCategoryId = 0;
        }
    }
    private async Task CreateCategoryAsync()
    {
        _creatingCategory = true;
        _referenceError = null;

        var response = await ReferenceApi.CreateCategoryAsync(Session, _newCategory.ToRequest());
        if (!response.Success || response.Data is null)
        {
            _referenceError = response.Message;
            _creatingCategory = false;
            return;
        }

        _categories.Add(response.Data);
        _categories = _categories.OrderBy(x => x.PrintName).ThenBy(x => x.Name).ToList();
        Model.CategoryId = response.Data.Id;
        Model.SubCategoryId = 0;
        _categoryMode = LookupMode.Select;
        _newCategory = new();
        await LoadSubCategoriesAsync(Model.CategoryId);
        _creatingCategory = false;
    }
    private async Task CreateSubCategoryAsync()
    {
        _creatingSubCategory = true;
        _referenceError = null;

        var response = await ReferenceApi.CreateSubCategoryAsync(Session, _newSubCategory.ToRequest(Model.CategoryId));
        if (!response.Success || response.Data is null)
        {
            _referenceError = response.Message;
            _creatingSubCategory = false;
            return;
        }

        _subCategories.Add(response.Data);
        _subCategories = _subCategories.OrderBy(x => x.PrintName).ThenBy(x => x.Name).ToList();
        Model.SubCategoryId = response.Data.Id;
        _subCategoryMode = LookupMode.Select;
        _newSubCategory = new();
        _creatingSubCategory = false;
    }
    private void OnTagToggled(int tagId, ChangeEventArgs e)
    {
        if (e.Value is bool checkedValue)
        {
            if (checkedValue)
            {
                if (!Model.TagIds.Contains(tagId)) Model.TagIds.Add(tagId);
            }
            else
            {
                Model.TagIds.Remove(tagId);
            }
        }
    }
    private string GetTagStyle(ProductTagDto tag)
    {
        if (string.IsNullOrWhiteSpace(tag.Color)) return "";
        return $"border-color: {tag.Color}; color: {tag.Color};";
    }
    private static string ModeButtonClass(LookupMode current, LookupMode target)
        => current == target ? "button slim" : "button secondary slim";

    private enum LookupMode
    {
        Select,
        Create
    }

    private sealed class CategoryDraft
    {
        public string NameCode { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string PrintName { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? CoverImageUrl { get; set; }

        public CreateProductCategoryRequest ToRequest()
            => new(NameCode, Name, PrintName, Slug, Description, CoverImageUrl);
    }

    private sealed class SubCategoryDraft
    {
        public string NameCode { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string PrintName { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? CoverImageUrl { get; set; }

        public CreateProductSubCategoryRequest ToRequest(int categoryId)
            => new(categoryId, NameCode, Name, PrintName, Slug, Description, CoverImageUrl);
    }
}
