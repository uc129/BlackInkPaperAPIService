<button type="button" @onclick="() => OnToggle.InvokeAsync(!Val)"
        style="display:flex;align-items:center;gap:14px;padding:12px 14px;border-radius:10px;
               border:1px solid @(Val ? "color-mix(in oklab, var(--accent) 35%, var(--line))" : "var(--line)");
               background:@(Val ? "var(--accent-soft)" : "var(--paper-50)");
               cursor:pointer;text-align:left;font-family:inherit;width:100%;
               transition:background .12s,border-color .12s">
    <div class="toggle-track" style="background:@(Val ? "var(--accent)" : "var(--paper-300)");flex-shrink:0;position:relative">
        <div style="position:absolute;top:2px;left:2px;width:14px;height:14px;
                    background:var(--paper-50);border-radius:50%;
                    transform:@(Val ? "translateX(14px)" : "translateX(0)");
                    transition:transform .15s;box-shadow:var(--shadow-sm)"></div>
    </div>
    <div style="flex:1">
        <div style="font-size:13.5px;font-weight:600;color:var(--ink-900)">@Label</div>
        @if (!string.IsNullOrEmpty(Hint))
        {
            <div style="font-size:12px;color:var(--ink-500)">@Hint</div>
        }
    </div>
</button>

@code {
    [Parameter] public bool Val { get; set; }
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Hint { get; set; } = "";
    [Parameter] public EventCallback<bool> OnToggle { get; set; }
}
