@inject NavigationManager Nav
@inject IAuthService AuthService

<aside class="sidebar">
    <div class="brand">
        <div class="brand-mark">B</div>
        <div>
            <div class="brand-name">Black Ink Paper</div>
            <div class="brand-meta">Admin · v1.0</div>
        </div>
    </div>

    <div class="nav-group">
        <div class="nav-group-label">Workspace</div>
        <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
            <Icon Name="home" CssClass="nav-icon" />
            <span>Dashboard</span>
        </NavLink>
        <NavLink class="nav-item" href="/products">
            <Icon Name="package" CssClass="nav-icon" />
            <span>Products</span>
        </NavLink>
        <NavLink class="nav-item" href="/orders">
            <Icon Name="receipt" CssClass="nav-icon" />
            <span>Orders</span>
        </NavLink>
    </div>

    <div class="nav-group">
        <div class="nav-group-label">Catalog</div>
        <NavLink class="nav-item" href="/catalog/categories">
            <Icon Name="layers" CssClass="nav-icon" />
            <span>Categories</span>
        </NavLink>
        <NavLink class="nav-item" href="/catalog/subcategories">
            <Icon Name="layers" CssClass="nav-icon" />
            <span>Subcategories</span>
        </NavLink>
        <NavLink class="nav-item" href="/catalog/tags">
            <Icon Name="tag" CssClass="nav-icon" />
            <span>Tags</span>
        </NavLink>
        <NavLink class="nav-item" href="/catalog/artists">
            <Icon Name="users" CssClass="nav-icon" />
            <span>Artists</span>
        </NavLink>
    </div>

    <div class="nav-group">
        <div class="nav-group-label">Account</div>
        <NavLink class="nav-item" href="/admin/users">
            <Icon Name="users" CssClass="nav-icon" />
            <span>Users</span>
        </NavLink>
        <NavLink class="nav-item" href="/settings">
            <Icon Name="settings" CssClass="nav-icon" />
            <span>Settings</span>
        </NavLink>
    </div>

    <div class="sidebar-footer">
        @{
            var user = AuthService.GetCurrentUser();
            var initials = user is not null
                ? string.Concat(user.Name.Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString() : "")).ToUpper()
                : "?";
            var displayName = user?.Name ?? "Admin";
            var displayRole = user?.Role ?? "";
        }
        <div class="avatar">@initials</div>
        <div class="flex-col" style="min-width:0">
            <div class="user-name">@displayName</div>
            @if (!string.IsNullOrEmpty(displayRole))
            {
                <div class="user-role">@displayRole</div>
            }
        </div>
        <button class="btn btn-icon btn-ghost" style="margin-left:auto" title="Sign out"
                @onclick="HandleLogout">
            <Icon Name="logout" />
        </button>
    </div>
</aside>

@code {
    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
