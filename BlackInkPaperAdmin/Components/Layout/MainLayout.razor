@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IAuthService AuthService
@inject TokenStore Store
@inject IJSRuntime JS
@implements IDisposable

@if (_ready)
{
    <div class="shell">
        <NavMenu />
        <div>
            <header class="topbar">
                <div class="crumbs">
                    @{
                        var crumbs = GetCrumbs();
                        for (var i = 0; i < crumbs.Length; i++)
                        {
                            if (i == crumbs.Length - 1)
                            {
                                <span class="here">@crumbs[i]</span>
                            }
                            else
                            {
                                <span>@crumbs[i]</span>
                                <span class="sep">›</span>
                            }
                        }
                    }
                </div>
                <div class="topbar-spacer"></div>
                <div class="topbar-actions">
                    <button class="btn btn-icon btn-ghost" title="Notifications">
                        <Icon Name="bell" />
                    </button>
                </div>
            </header>
            <main class="content">
                @Body
            </main>
        </div>
    </div>
}

@code {
    private bool _ready;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (Store.Token is not null)
        {
            _ready = true;
            StateHasChanged();
            return;
        }

        string? saved = null;
        try { saved = await JS.InvokeAsync<string?>("localStorage.getItem", "bip_admin_token"); } catch { }

        if (!string.IsNullOrEmpty(saved) && await AuthService.InitializeAsync(saved))
        {
            _ready = true;
            StateHasChanged();
        }
        else
        {
            if (!string.IsNullOrEmpty(saved))
                try { await JS.InvokeVoidAsync("localStorage.removeItem", "bip_admin_token"); } catch { }
            Nav.NavigateTo("/login");
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => StateHasChanged();

    private string[] GetCrumbs()
    {
        var path = new Uri(Nav.Uri).LocalPath.TrimEnd('/');
        return path switch
        {
            "" or "/"                   => ["Workspace", "Dashboard"],
            "/products"                 => ["Workspace", "Products"],
            "/products/create"          => ["Workspace", "Products", "New product"],
            var p when p.StartsWith("/products/") && p.EndsWith("/edit") => ["Workspace", "Products", "Edit product"],
            "/catalog/categories"       => ["Catalog", "Categories"],
            "/catalog/subcategories"    => ["Catalog", "Subcategories"],
            "/catalog/tags"             => ["Catalog", "Tags"],
            "/catalog/artists"          => ["Catalog", "Artists"],
            "/orders"                   => ["Workspace", "Orders"],
            var p when p.StartsWith("/orders/") => ["Workspace", "Orders", "Order detail"],
            "/admin/users"              => ["Account", "Users"],
            "/settings"                 => ["Account", "Settings"],
            _                           => ["Black Ink Paper"],
        };
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
