@inherits LayoutComponentBase
@inject NavigationManager Nav
@implements IDisposable

<div class="shell" data-density="@_density">
    <NavMenu />
    <div>
        <header class="topbar">
            <div class="crumbs">
                @{
                    var crumbs = GetCrumbs();
                    for (var i = 0; i < crumbs.Length; i++)
                    {
                        if (i == crumbs.Length - 1)
                        {
                            <span class="here">@crumbs[i]</span>
                        }
                        else
                        {
                            <span>@crumbs[i]</span>
                            <span class="sep">›</span>
                        }
                    }
                }
            </div>
            <div class="topbar-spacer"></div>
            <div class="topbar-actions">
                <div class="density-toggle" title="Density">
                    <button class="@(_density == "comfortable" ? "on" : "")" @onclick='() => SetDensity("comfortable")'>
                        <Icon Name="rows" Size="12" /> Comfy
                    </button>
                    <button class="@(_density == "compact" ? "on" : "")" @onclick='() => SetDensity("compact")'>
                        <Icon Name="grid3" Size="12" /> Compact
                    </button>
                </div>
                <button class="btn btn-icon btn-ghost" title="Notifications">
                    <Icon Name="bell" />
                </button>
            </div>
        </header>
        <main class="content">
            @Body
        </main>
    </div>
</div>

@code {
    private string _density = "comfortable";

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => StateHasChanged();

    private void SetDensity(string d) => _density = d;

    private string[] GetCrumbs()
    {
        var path = new Uri(Nav.Uri).LocalPath.TrimEnd('/');
        return path switch
        {
            "" or "/"                   => ["Workspace", "Dashboard"],
            "/products"                 => ["Workspace", "Products"],
            "/products/create"          => ["Workspace", "Products", "New product"],
            var p when p.StartsWith("/products/edit") => ["Workspace", "Products", "Edit product"],
            "/catalog/categories"       => ["Catalog", "Categories"],
            "/catalog/subcategories"    => ["Catalog", "Subcategories"],
            "/catalog/tags"             => ["Catalog", "Tags"],
            "/catalog/artists"          => ["Catalog", "Artists"],
            "/settings"                 => ["Account", "Settings"],
            _                           => ["Black Ink Paper"],
        };
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
