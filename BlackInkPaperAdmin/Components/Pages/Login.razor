@page "/login"
@inject AuthApiClient AuthApiClient
@inject AdminSession Session
@inject NavigationManager Navigation
@inject ILogger<Login> Logger


<PageTitle>Login</PageTitle>

<div class="auth-shell">
    <div class="auth-card">
        <div class="eyebrow">Admin Access</div>
        <h1>Sign in</h1>
        <p class="muted">Use an `Artist` or `Admin` account from your API.</p>

        <EditForm Model="model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <label>Email</label>
            <InputText @bind-Value="model.Email" class="input" />

            <label>Password</label>
            <InputText @bind-Value="model.Password" type="password" class="input" />

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <p class="error-text">@errorMessage</p>
            }

            <button class="button" disabled="@submitting">
                @(submitting ? "Signing in..." : "Login")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private readonly LoginFormModel model = new();
    private bool submitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/products", true);
        }
    }

    private async Task SubmitAsync()
    {
        submitting = true;
        errorMessage = null;
        Logger.LogInformation("Login attempt for user: {Email}", model.Email);
        try
        {
            var response = await AuthApiClient.LoginAsync(new LoginRequest(model.Email, model.Password));
            if (!response.Success || response.Data is null)
            {
                errorMessage = response.Message;
                Logger.LogWarning("Login failed for {Email}: {Reason}", model.Email, response.Message);
                submitting = false;
                return;
            }
            Console.WriteLine(response.Data.Token);
            await Session.SetTokenAsync(response.Data.Token);
            Navigation.NavigateTo("/products");
        }
        catch(Exception ex)
        {
            submitting = false;
            Logger.LogWarning("Login failed for {Email}: {Reason}", model.Email, ex.Message);
        }
        finally
        {
            submitting = false;
        }
    }

    private sealed class LoginFormModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;
    }
}
