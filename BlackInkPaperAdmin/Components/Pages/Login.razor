@page "/login"
@layout EmptyLayout
<PageTitle>Sign in — Black Ink Paper Admin</PageTitle>

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-brand">
            <div class="brand-mark">B</div>
            <div>
                <div class="brand-name">Black Ink Paper</div>
                <div class="brand-meta">Admin</div>
            </div>
        </div>
        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-sub">Sign in to manage your catalog and orders.</p>
        <div class="auth-form">
            <div class="field-block">
                <label class="lbl">Email</label>
                <div class="field">
                    <Icon Name="mail" />
                    <input type="email" @bind="_email" placeholder="you@example.com" />
                </div>
            </div>
            <div class="field-block">
                <div class="row">
                    <label class="lbl">Password</label>
                    <span class="spacer"></span>
                    <a href="#" class="link" style="font-size:12px">Forgot?</a>
                </div>
                <div class="field">
                    <Icon Name="lock" />
                    <input type="password" @bind="_password" placeholder="••••••••" />
                </div>
            </div>
            @if (_error is not null)
            {
                <div style="font-size:13px;color:var(--danger);display:flex;gap:6px;align-items:center">
                    <Icon Name="alert" Size="13" /> @_error
                </div>
            }
            <button class="btn btn-primary btn-full" @onclick="HandleLogin" disabled="@_loading">
                @(_loading ? "Signing in…" : "Sign in")
            </button>
        </div>
        <div class="auth-foot">Need help? <a href="#" class="link">Contact support</a></div>
    </div>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _loading = true;
        _error = null;
        await Task.Delay(600); // TODO: call auth API
        _error = "Invalid credentials — API not wired up yet.";
        _loading = false;
    }
}
