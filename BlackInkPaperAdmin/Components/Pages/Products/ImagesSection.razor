<section id="section-images" class="section">
    <div class="section-head">
        <div>
            <h3 class="h-section">Images</h3>
            <div class="meta">Cover and header image URLs.</div>
        </div>
        <button class="btn btn-secondary btn-sm" disabled>
            <Icon Name="upload" /> Upload
        </button>
    </div>
    <div class="section-body">
        <div class="grid-2">
            <div class="field-block">
                <label class="lbl">Cover image URL</label>
                <div class="field">
                    <Icon Name="image" />
                    <input @bind="Vm.CoverUrl" @bind:after="NotifyChanged" placeholder="https://res.cloudinary.com/…" />
                </div>
                <div class="hint">Main catalog image (4:5 ratio recommended).</div>
            </div>
            <div class="field-block">
                <label class="lbl">Header image URL</label>
                <div class="field">
                    <Icon Name="image" />
                    <input @bind="Vm.HeaderUrl" @bind:after="NotifyChanged" placeholder="https://res.cloudinary.com/…" />
                </div>
                <div class="hint">Wide banner shown on the product page.</div>
            </div>
        </div>
        <div class="mt-3 image-grid">
            @if (!string.IsNullOrEmpty(Vm.CoverUrl))
            {
                <div class="image-tile">
                    <div class="primary-tag">Cover</div>
                    <img src="@Vm.CoverUrl" alt="Cover"
                         style="width:100%;height:100%;object-fit:cover" />
                </div>
            }
            <div class="image-tile upload">
                <div class="flex-col gap-2" style="align-items:center">
                    <Icon Name="upload" Size="20" />
                    <span>Cloudinary upload<br />coming soon</span>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public ProductFormViewModel Vm { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private Task NotifyChanged() => OnChanged.InvokeAsync();
}
