@page "/products/new"
@inject ProductAdminApiClient ProductsApi
@inject AdminSession Session
@inject NavigationManager Navigation

<PageTitle>Create Product</PageTitle>

<h1>Create Product</h1>

<ProductEditorForm Model="_model" SubmitLabel="Create Product" ErrorMessage="errorMessage" OnValidSubmit="SaveAsync" IsCreateMode="true" />

@code {
    private readonly ProductEditorModel _model = ProductEditorModel.CreateDefault();
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", true);
        }
    }

    private async Task SaveAsync()
    {
        var response = await ProductsApi.CreateAsync(Session, _model.ToCreateRequest());
        if (!response.Success || response.Data is null)
        {
            _errorMessage = response.Message;
            return;
        }

        Navigation.NavigateTo($"/products/{response.Data.Id}", true);
    }
}
