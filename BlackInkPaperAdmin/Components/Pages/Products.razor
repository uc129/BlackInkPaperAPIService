@page "/products"
@namespace BlackInkPaperAdmin.Pages.ProductList
@inject HttpClient Http
@inject NavigationManager Nav
<PageTitle>Products — Black Ink Paper Admin</PageTitle>

<div class="page-header">
    <div>
        <h1 class="h-page">Products</h1>
        <p class="lead">Manage prints, digital downloads and limited editions.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-secondary" disabled><Icon Name="upload" /> Import CSV</button>
        <a href="/products/create" class="btn btn-primary"><Icon Name="plus" /> New product</a>
    </div>
</div>

<div class="card products-list">
    <div class="toolbar">
        <div class="chips">
            <button class="chip @(_filter == "all" ? "on" : "")" @onclick='() => SetFilter("all")'>
                All <span class="count">@_all.Count</span>
            </button>
            <button class="chip @(_filter == "available" ? "on" : "")" @onclick='() => SetFilter("available")'>
                Available <span class="count">@_countAvailable</span>
            </button>
            <button class="chip @(_filter == "draft" ? "on" : "")" @onclick='() => SetFilter("draft")'>
                Drafts <span class="count">@_countDraft</span>
            </button>
            <button class="chip @(_filter == "featured" ? "on" : "")" @onclick='() => SetFilter("featured")'>
                Featured <span class="count">@_countFeatured</span>
            </button>
            <button class="chip @(_filter == "out" ? "on" : "")" @onclick='() => SetFilter("out")'>
                Out of stock <span class="count">@_countOut</span>
            </button>
        </div>
        <span class="spacer"></span>
        <div class="field" style="max-width:320px">
            <Icon Name="search" />
            <input placeholder="Search by name, code or artist…" value="@_query"
                   @oninput="OnSearch" />
        </div>
    </div>

    @if (_loading)
    {
        <div class="list-header">
            <span></span><span>Product</span><span>Artist &amp; Category</span><span>Price</span><span>Stock</span><span></span>
        </div>
        @for (int i = 0; i < 5; i++)
        {
            <div class="product-row">
                <div class="skel" style="width:48px;height:48px;border-radius:8px"></div>
                <div class="flex-col gap-2">
                    <div class="skel" style="height:12px;width:55%"></div>
                    <div class="skel" style="height:10px;width:30%"></div>
                </div>
                <div class="flex-col gap-2">
                    <div class="skel" style="height:12px;width:70%"></div>
                    <div class="skel" style="height:10px;width:40%"></div>
                </div>
                <div class="skel" style="height:14px;width:60px"></div>
                <div class="skel" style="height:20px;width:50px;border-radius:999px"></div>
                <div></div>
            </div>
        }
    }
    else if (_error is not null)
    {
        <div class="state">
            <div class="state-art"><Icon Name="alert" Size="28" StrokeWidth="1.3" /></div>
            <h3>Could not load products</h3>
            <p>@_error</p>
            <div class="state-actions">
                <button class="btn btn-secondary" @onclick="LoadProducts"><Icon Name="refresh" /> Retry</button>
            </div>
        </div>
    }
    else if (_filtered.Count == 0 && _all.Count > 0)
    {
        <div class="state">
            <div class="state-art"><Icon Name="search" Size="28" StrokeWidth="1.3" /></div>
            <h3>No matches</h3>
            <p>Try a different search term or filter.</p>
            <div class="state-actions">
                <button class="btn btn-secondary" @onclick="ClearFilter">Clear filter</button>
            </div>
        </div>
    }
    else if (_all.Count == 0)
    {
        <div class="state">
            <div class="state-art"><Icon Name="package" Size="28" StrokeWidth="1.3" /></div>
            <h3>No products yet</h3>
            <p>Add your first print, digital download or limited edition.</p>
            <div class="state-actions">
                <a href="/products/create" class="btn btn-primary"><Icon Name="plus" /> New product</a>
            </div>
        </div>
    }
    else
    {
        <div class="list-header">
            <span></span>
            <span class="sortable" @onclick='() => SortBy("name")'>Product @SortArrow("name")</span>
            <span>Artist &amp; Category</span>
            <span class="sortable" @onclick='() => SortBy("price")'>Price @SortArrow("price")</span>
            <span>Stock</span>
            <span></span>
        </div>
        @foreach (var p in _filtered)
        {
            var pid = p.Id;
            <div class="product-row">
                <div class="product-thumb">
                    <Icon Name="image" Size="18" />
                </div>
                <div>
                    <div class="product-name">@p.Name</div>
                    <div class="product-meta">
                        <span class="mono">@p.ProductId</span>
                        <span class="sep">·</span>
                        <span class="badge @(p.Taxonomy.IsAvailable ? "live" : "draft")">
                            <span class="dot"></span> @(p.Taxonomy.IsAvailable ? "live" : "draft")
                        </span>
                        @if (p.Taxonomy.IsFeatured)
                        {
                            <span class="badge featured"><Icon Name="star" Size="10" /> Featured</span>
                        }
                    </div>
                </div>
                <div>
                    <div style="font-size:13.5px;font-weight:500">Artist @p.ArtistId</div>
                    <div class="product-meta">Cat. @p.Taxonomy.CategoryId</div>
                </div>
                <div>
                    @if (p.Pricing.BasePrice > p.Pricing.FinalPrice)
                    {
                        <span class="product-price">
                            <span class="strike">@FmtINR(p.Pricing.BasePrice)</span>
                            @FmtINR(p.Pricing.FinalPrice)
                        </span>
                    }
                    else
                    {
                        <span class="product-price">@FmtINR(p.Pricing.FinalPrice)</span>
                    }
                </div>
                <div>
                    @{
                        var stock = p.Stats.StockQuantity;
                        var stockCss = stock == 0 ? "out" : stock < 5 ? "low" : "";
                        var stockText = stock == 0 ? "Out of stock" : stock < 5 ? $"{stock} left" : $"{stock} in stock";
                    }
                    <span class="product-stock @stockCss">@stockText</span>
                </div>
                <div class="row-actions">
                    <button class="btn btn-icon btn-ghost" title="Edit" @onclick="() => GoEdit(pid)">
                        <Icon Name="edit" />
                    </button>
                    <button class="btn btn-icon btn-ghost" title="View" disabled>
                        <Icon Name="eye" />
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<ProductSummaryDto> _all = new();
    private List<ProductSummaryDto> _filtered = new();
    private string _filter = "all";
    private string _query = "";
    private string? _sortKey;
    private bool _sortAsc = true;
    private bool _loading = true;
    private string? _error;
    private int _countAvailable;
    private int _countDraft;
    private int _countFeatured;
    private int _countOut;

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        _loading = true;
        _error = null;
        try
        {
            var resp = await Http.GetFromJsonAsync<ServiceResponse<PagedResultDto<ProductSummaryDto>>>(
                "api/admin/products?Page=1&PageSize=100");
            if (resp?.Success == true && resp.Data is not null)
            {
                _all = resp.Data.Items.ToList();
                _countAvailable = _all.Count(p => p.Taxonomy.IsAvailable && (p.Stats.StockQuantity ?? 1) > 0);
                _countDraft     = _all.Count(p => !p.Taxonomy.IsAvailable);
                _countFeatured  = _all.Count(p => p.Taxonomy.IsFeatured);
                _countOut       = _all.Count(p => p.Stats.StockQuantity == 0);
            }
            else
                _error = resp?.Message ?? "Unknown error";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        ApplyFilter();
        _loading = false;
    }

    private void GoEdit(int id) => Nav.NavigateTo($"/products/{id}/edit");

    private void SetFilter(string f) { _filter = f; ApplyFilter(); }
    private void ClearFilter() { _filter = "all"; _query = ""; ApplyFilter(); }

    private void OnSearch(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? "";
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        var list = _all.AsEnumerable();
        list = _filter switch
        {
            "available" => list.Where(p => p.Taxonomy.IsAvailable && (p.Stats.StockQuantity ?? 1) > 0),
            "draft"     => list.Where(p => !p.Taxonomy.IsAvailable),
            "featured"  => list.Where(p => p.Taxonomy.IsFeatured),
            "out"       => list.Where(p => p.Stats.StockQuantity == 0),
            _           => list,
        };
        if (!string.IsNullOrWhiteSpace(_query))
        {
            var q = _query.Trim().ToLowerInvariant();
            list = list.Where(p =>
                p.Name.ToLowerInvariant().Contains(q) ||
                p.ProductId.ToLowerInvariant().Contains(q));
        }
        if (_sortKey == "name")
            list = _sortAsc ? list.OrderBy(p => p.Name) : list.OrderByDescending(p => p.Name);
        else if (_sortKey == "price")
            list = _sortAsc ? list.OrderBy(p => p.Pricing.FinalPrice) : list.OrderByDescending(p => p.Pricing.FinalPrice);

        _filtered = list.ToList();
    }

    private void SortBy(string key)
    {
        if (_sortKey == key) _sortAsc = !_sortAsc;
        else { _sortKey = key; _sortAsc = true; }
        ApplyFilter();
    }

    private MarkupString SortArrow(string key)
    {
        if (_sortKey != key) return (MarkupString)"";
        return (MarkupString)(_sortAsc ? " ↑" : " ↓");
    }

    private static string FmtINR(decimal amount) => CurrencyHelper.FmtINR(amount);
}
