@page "/products"
<PageTitle>Products — Black Ink Paper Admin</PageTitle>

<div class="page-header">
    <div>
        <h1 class="h-page">Products</h1>
        <p class="lead">Manage prints, digital downloads and limited editions.</p>
    </div>
    <div class="page-actions">
        <a href="/products/create" class="btn btn-primary"><Icon Name="plus" /> New product</a>
    </div>
</div>

<div class="card">
    <div class="state">
        <div class="state-art"><Icon Name="package" Size="36" StrokeWidth="1.3" /></div>
        <h3>Products list coming next</h3>
        <p>Full filter, search and sort table will be built in the next step.</p>
        <div class="state-actions">
            <a href="/products/create" class="btn btn-primary"><Icon Name="plus" /> New product</a>
        </div>
    </div>
</div>
