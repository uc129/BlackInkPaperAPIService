@page "/catalog/tags"
@inject HttpClient Http
<PageTitle>Tags — Black Ink Paper Admin</PageTitle>

<div class="page-header">
    <div>
        <h1 class="h-page">Tags</h1>
        <p class="lead">Free-form labels customers can filter by.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-primary" @onclick="OpenCreate">
            <Icon Name="plus" /> New tag
        </button>
    </div>
</div>

<div class="card">
    <div class="toolbar">
        <div class="field" style="max-width:320px">
            <Icon Name="search" />
            <input placeholder="Search tags…" value="@_query" @oninput="OnSearch" />
        </div>
        <span class="spacer"></span>
        <span style="font-size:13px;color:var(--ink-400)">@_all.Count tag@(_all.Count == 1 ? "" : "s")</span>
    </div>

    @if (_loading)
    {
        <div class="list-header" style="grid-template-columns:auto 1fr 1fr auto">
            <span></span><span>Name</span><span>Slug</span><span></span>
        </div>
        @for (int i = 0; i < 6; i++)
        {
            <div class="tag-row">
                <div class="skel" style="width:20px;height:20px;border-radius:50%"></div>
                <div class="skel" style="height:13px;width:50%"></div>
                <div class="skel" style="height:11px;width:60%"></div>
                <div></div>
            </div>
        }
    }
    else if (_error is not null)
    {
        <div class="state">
            <div class="state-art"><Icon Name="alert" Size="28" StrokeWidth="1.3" /></div>
            <h3>Could not load tags</h3>
            <p>@_error</p>
            <div class="state-actions">
                <button class="btn btn-secondary" @onclick="Load"><Icon Name="refresh" /> Retry</button>
            </div>
        </div>
    }
    else if (_filtered.Count == 0 && _all.Count > 0)
    {
        <div class="state">
            <div class="state-art"><Icon Name="search" Size="28" StrokeWidth="1.3" /></div>
            <h3>No matches</h3>
            <p>Try a different search term.</p>
        </div>
    }
    else if (_all.Count == 0)
    {
        <div class="state">
            <div class="state-art"><Icon Name="tag" Size="28" StrokeWidth="1.3" /></div>
            <h3>No tags yet</h3>
            <p>Create tags to help customers discover products by theme or medium.</p>
            <div class="state-actions">
                <button class="btn btn-primary" @onclick="OpenCreate"><Icon Name="plus" /> New tag</button>
            </div>
        </div>
    }
    else
    {
        <div class="list-header" style="grid-template-columns:auto 1fr 1fr auto">
            <span></span><span>Name</span><span>Slug</span><span></span>
        </div>
        @foreach (var t in _filtered)
        {
            var tid = t.Id;
            var swatch = string.IsNullOrEmpty(t.Color) ? "var(--paper-300)" : t.Color;
            <div class="tag-row">
                <div style="width:20px;height:20px;border-radius:50%;background:@swatch;flex-shrink:0;border:1px solid var(--line)"></div>
                <div style="font-weight:600;font-size:14px">@t.Name</div>
                <div class="mono" style="font-size:12.5px;color:var(--ink-500)">@t.Slug</div>
                <div class="row-actions">
                    <button class="btn btn-icon btn-ghost" title="Edit" @onclick="() => OpenEdit(tid)">
                        <Icon Name="edit" />
                    </button>
                    <button class="btn btn-icon btn-ghost" title="Delete"
                            style="color:var(--danger)"
                            @onclick="() => ConfirmDelete(tid)">
                        <Icon Name="trash" />
                    </button>
                </div>
            </div>
        }
    }
</div>

@if (_showForm)
{
    <div class="overlay" @onclick="CloseForm">
        <div class="modal" style="max-width:400px" @onclick:stopPropagation>
            <div class="modal-head">
                <h2 class="h-section">@(_editId == 0 ? "New tag" : "Edit tag")</h2>
                <button class="btn btn-icon btn-ghost" @onclick="CloseForm"><Icon Name="x" /></button>
            </div>
            <div class="modal-body">
                <div class="field-block">
                    <label class="lbl">Name <span style="color:var(--danger)">*</span></label>
                    <div class="field">
                        <input value="@_fName" @oninput="OnNameInput" placeholder="e.g. Ink & Wash" />
                    </div>
                </div>
                <div class="field-block">
                    <label class="lbl">Slug</label>
                    <div class="field">
                        <input @bind="_fSlug" placeholder="e.g. ink-wash" />
                    </div>
                </div>
                <div class="field-block">
                    <label class="lbl">Colour</label>
                    <div style="display:flex;gap:10px;align-items:center">
                        <div class="field" style="flex:1">
                            <input @bind="_fColor" placeholder="#a06040 or oklch(…)" />
                        </div>
                        @if (!string.IsNullOrEmpty(_fColor))
                        {
                            <div style="width:32px;height:32px;border-radius:50%;background:@_fColor;border:1px solid var(--line);flex-shrink:0"></div>
                        }
                    </div>
                    <span class="hint">Any valid CSS colour value</span>
                </div>
                @if (_formError is not null)
                {
                    <div style="font-size:13px;color:var(--danger);display:flex;gap:6px;align-items:center">
                        <Icon Name="alert" Size="13" /> @_formError
                    </div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                <span class="spacer"></span>
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                    @(_saving ? "Saving…" : "Save tag")
                </button>
            </div>
        </div>
    </div>
}

@if (_deleteId != 0)
{
    <DeleteConfirmModal EntityName="tag"
        BodyText="This will remove the tag from all products."
        Error="@_deleteError" Deleting="@_deleting"
        OnConfirm="DeleteConfirmed"
        OnCancel="() => _deleteId = 0" />
}

<Toast Message="@_toast" />

<style>
    .tag-row {
        display: grid;
        grid-template-columns: auto 1fr 1fr auto;
        align-items: center;
        gap: 16px;
        padding: 11px 18px;
        border-bottom: 1px solid var(--line-soft);
    }
    .tag-row:last-child { border-bottom: 0; }
    .tag-row:hover { background: var(--paper-100); }
    .tag-row .row-actions { display: flex; gap: 2px; opacity: 0.6; transition: opacity 0.12s; }
    .tag-row:hover .row-actions { opacity: 1; }
</style>

@code {
    private List<ProductTagDto> _all = new();
    private List<ProductTagDto> _filtered = new();
    private string _query = "";
    private bool _loading = true;
    private string? _error;

    private bool _showForm;
    private int _editId;
    private string _fName = "", _fSlug = "", _fColor = "";
    private string? _formError;
    private bool _saving;

    private int _deleteId;
    private string? _deleteError;
    private bool _deleting;
    private string? _toast;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true; _error = null;
        try
        {
            var resp = await Http.GetFromJsonAsync<ServiceResponse<IReadOnlyList<ProductTagDto>>>(
                "api/admin/product-options/tags");
            if (resp?.Success == true && resp.Data is not null)
                _all = resp.Data.ToList();
            else
                _error = resp?.Message ?? "Unknown error";
        }
        catch (Exception ex) { _error = ex.Message; }
        ApplyFilter();
        _loading = false;
    }

    private void OnSearch(ChangeEventArgs e) { _query = e.Value?.ToString() ?? ""; ApplyFilter(); }

    private void ApplyFilter()
    {
        var q = _query.Trim().ToLowerInvariant();
        _filtered = string.IsNullOrEmpty(q)
            ? _all.ToList()
            : _all.Where(t => t.Name.ToLowerInvariant().Contains(q) || t.Slug.ToLowerInvariant().Contains(q)).ToList();
    }

    private void OpenCreate()
    {
        _editId = 0; _fName = ""; _fSlug = ""; _fColor = ""; _formError = null; _showForm = true;
    }

    private void OpenEdit(int id)
    {
        var t = _all.First(x => x.Id == id);
        _editId = id; _fName = t.Name; _fSlug = t.Slug; _fColor = t.Color ?? "";
        _formError = null; _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private void OnNameInput(ChangeEventArgs e)
    {
        _fName = e.Value?.ToString() ?? "";
        if (_editId == 0) _fSlug = SlugHelper.Slugify(_fName);
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_fName)) { _formError = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(_fSlug)) { _formError = "Slug is required."; return; }
        _saving = true; _formError = null;
        try
        {
            var body = new { name = _fName, slug = _fSlug, color = _fColor };
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            HttpResponseMessage resp = _editId == 0
                ? await Http.PostAsJsonAsync("api/admin/product-options/tags", body)
                : await Http.PutAsJsonAsync($"api/admin/product-options/tags/{_editId}", body);

            var result = await resp.Content.ReadFromJsonAsync<ServiceResponse<ProductTagDto>>(opts);
            if (result?.Success == true)
            {
                _showForm = false; await Load();
                ShowToast(_editId == 0 ? "Tag created." : "Tag updated.");
            }
            else { _formError = result?.Message ?? "Save failed."; }
        }
        catch (Exception ex) { _formError = ex.Message; }
        _saving = false;
    }

    private void ConfirmDelete(int id) { _deleteId = id; _deleteError = null; }

    private async Task DeleteConfirmed()
    {
        _deleting = true; _deleteError = null;
        try
        {
            var resp = await Http.DeleteAsync($"api/admin/product-options/tags/{_deleteId}");
            var result = await resp.Content.ReadFromJsonAsync<ServiceResponse<bool>>(
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (result?.Success == true) { _deleteId = 0; await Load(); ShowToast("Tag deleted."); }
            else _deleteError = result?.Message ?? "Delete failed.";
        }
        catch (Exception ex) { _deleteError = ex.Message; }
        _deleting = false;
    }

    private async void ShowToast(string msg)
    {
        _toast = msg; StateHasChanged();
        await Task.Delay(3000);
        _toast = null; StateHasChanged();
    }

}
