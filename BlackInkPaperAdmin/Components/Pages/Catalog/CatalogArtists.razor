@page "/catalog/artists"
@inject HttpClient Http
<PageTitle>Artists — Black Ink Paper Admin</PageTitle>

<div class="page-header">
    <div>
        <h1 class="h-page">Artists</h1>
        <p class="lead">Registered artists whose works appear in the catalog.</p>
    </div>
</div>

<div class="card">
    <div class="toolbar">
        <div class="field" style="max-width:320px">
            <Icon Name="search" />
            <input placeholder="Search artists…" value="@_query" @oninput="OnSearch" />
        </div>
        <span class="spacer"></span>
        <span style="font-size:13px;color:var(--ink-400)">@_all.Count artist@(_all.Count == 1 ? "" : "s")</span>
    </div>

    @if (_loading)
    {
        <div class="list-header" style="grid-template-columns:auto 1fr auto">
            <span></span><span>Artist</span><span></span>
        </div>
        @for (int i = 0; i < 5; i++)
        {
            <div class="artist-row">
                <div class="skel" style="width:36px;height:36px;border-radius:50%"></div>
                <div>
                    <div class="skel" style="height:13px;width:45%"></div>
                    <div class="skel" style="height:10px;width:30%;margin-top:5px"></div>
                </div>
                <div></div>
            </div>
        }
    }
    else if (_error is not null)
    {
        <div class="state">
            <div class="state-art"><Icon Name="alert" Size="28" StrokeWidth="1.3" /></div>
            <h3>Could not load artists</h3>
            <p>@_error</p>
            <div class="state-actions">
                <button class="btn btn-secondary" @onclick="Load"><Icon Name="refresh" /> Retry</button>
            </div>
        </div>
    }
    else if (_filtered.Count == 0 && _all.Count > 0)
    {
        <div class="state">
            <div class="state-art"><Icon Name="search" Size="28" StrokeWidth="1.3" /></div>
            <h3>No matches</h3>
            <p>Try a different search term.</p>
        </div>
    }
    else if (_all.Count == 0)
    {
        <div class="state">
            <div class="state-art"><Icon Name="users" Size="28" StrokeWidth="1.3" /></div>
            <h3>No artists yet</h3>
            <p>Artists are created through account registration with the Artist role.</p>
        </div>
    }
    else
    {
        <div class="list-header" style="grid-template-columns:auto 1fr auto">
            <span></span><span>Artist</span><span>ID</span>
        </div>
        @foreach (var a in _filtered)
        {
            var initials = string.Concat(
                a.DisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                             .Take(2)
                             .Select(w => char.ToUpper(w[0])));
            <div class="artist-row">
                @if (!string.IsNullOrEmpty(a.ProfileImageUrl))
                {
                    <img src="@a.ProfileImageUrl" alt="@a.DisplayName"
                         style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:1px solid var(--line);flex-shrink:0" />
                }
                else
                {
                    <div class="avatar" style="font-size:11px">@initials</div>
                }
                <div>
                    <div style="display:flex;align-items:center;gap:8px">
                        <span style="font-weight:600;font-size:14px">@a.DisplayName</span>
                        @if (a.IsVerified)
                        {
                            <span class="badge live" style="font-size:11px;padding:2px 7px">
                                <Icon Name="check" Size="10" /> Verified
                            </span>
                        }
                    </div>
                </div>
                <div class="mono" style="font-size:12px;color:var(--ink-400)">#@a.Id</div>
            </div>
        }
    }
</div>

<div class="card card-pad mt-4" style="background:var(--paper-100)">
    <div style="display:flex;gap:14px;align-items:flex-start">
        <div style="color:var(--ink-400);margin-top:2px"><Icon Name="info" Size="16" /></div>
        <div>
            <div style="font-weight:600;font-size:13.5px;margin-bottom:3px">Adding artists</div>
            <p style="font-size:13px;color:var(--ink-500);margin:0">
                Artists are registered via the account registration endpoint with the <span class="mono">Artist</span> role.
                Use <span class="mono">POST /api/accounts/register</span> with <span class="mono">"Role": "Artist"</span> to create a new artist account.
            </p>
        </div>
    </div>
</div>

<style>
    .artist-row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 16px;
        padding: 12px 18px;
        border-bottom: 1px solid var(--line-soft);
    }
    .artist-row:last-child { border-bottom: 0; }
    .artist-row:hover { background: var(--paper-100); }
</style>

@code {
    private List<ArtistLookupDto> _all = new();
    private List<ArtistLookupDto> _filtered = new();
    private string _query = "";
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true; _error = null;
        try
        {
            var resp = await Http.GetFromJsonAsync<ServiceResponse<IReadOnlyList<ArtistLookupDto>>>(
                "api/admin/product-options/artists");
            if (resp?.Success == true && resp.Data is not null)
                _all = resp.Data.ToList();
            else
                _error = resp?.Message ?? "Unknown error";
        }
        catch (Exception ex) { _error = ex.Message; }
        ApplyFilter();
        _loading = false;
    }

    private void OnSearch(ChangeEventArgs e) { _query = e.Value?.ToString() ?? ""; ApplyFilter(); }

    private void ApplyFilter()
    {
        var q = _query.Trim().ToLowerInvariant();
        _filtered = string.IsNullOrEmpty(q)
            ? _all.ToList()
            : _all.Where(a => a.DisplayName.ToLowerInvariant().Contains(q)).ToList();
    }

}
